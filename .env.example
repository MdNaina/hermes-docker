# Copy to .env or run ./setup-hermes-env.
# Keep real .env files private; they contain passwords and host paths.

COMPOSE_PROJECT_NAME="hermes-docker"
HERMES_CONTAINER_NAME="hermes-docker"

# local publishes ports to the host; server exposes container ports only.
COMPOSE_PROFILES="server"
HERMES_CONFIG_VOLUME="./data"
HERMES_BACKUP_DIR="./backups"

INSTALL_OPTIONAL_BUILD_TOOLS=false
OBSIDIAN_VERSION="1.12.7"
PREBUILD_HERMES_UI=false
FASTER_WHISPER_VERSION="1.2.1"

CUSTOM_USER="abc"
PASSWORD="change-this-desktop-password"
TITLE="Hermes Desktop"
PUID=1000
PGID=1000
TZ="Etc/UTC"

PIXELFLUX_WAYLAND=false
HERMES_BIND_ADDRESS="127.0.0.1"
HERMES_DESKTOP_HTTPS_HOST_PORT="3001"
HERMES_DESKTOP_HTTP_HOST_PORT="3000"
HERMES_GATEWAY_HOST_PORT="8642"
HERMES_DASHBOARD_HOST_PORT="9119"

HERMES_DASHBOARD=1
HERMES_DASHBOARD_HOST="0.0.0.0"
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_BASIC_AUTH_USERNAME="abc"
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD="change-this-dashboard-password"

BROWSER_HARNESS_HOME="/config/.browser-harness"
BH_HOME="/config/.browser-harness"
BH_DOMAIN_SKILLS=0
FASTER_WHISPER_HOME="/config/.cache/faster-whisper"
HF_HOME="/config/.cache/huggingface"
OBSIDIAN_AUTOSTART=0
