#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_ENV="${PROJECT_DIR}/.env"
DEFAULT_CONFIG="${PROJECT_DIR}/root/defaults/hermes/config.yaml"
DEPLOYMENT_PROFILE="server"
HERMES_DATA_DIR="${PROJECT_DIR}/data"
HERMES_HOME="${HERMES_DATA_DIR}/.hermes"
HERMES_ENV="${HERMES_HOME}/.env"
HERMES_CONFIG="${HERMES_HOME}/config.yaml"
GENERATED_DESKTOP_PASSWORD=""
DASHBOARD_REUSES_DESKTOP_PASSWORD=false
DEFAULT_INSTANCE_NAME=""

say() {
    printf '%s\n' "$*"
}

generate_secret() {
    if command -v openssl >/dev/null 2>&1; then
        openssl rand -hex 32
    else
        od -An -tx1 -N32 /dev/urandom | tr -d ' \n'
    fi
}

sanitize_instance_name() {
    local value="$1"
    value="$(printf '%s' "${value}" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9_.-]+/-/g; s/^[^a-z0-9]+//; s/[^a-z0-9]+$//')"
    if [ -z "${value}" ]; then
        value="hermes-docker"
    fi
    printf '%s' "${value}"
}

normalize_host_path() {
    local value="$1"
    case "${value}" in
        "~") value="${HOME:-${PROJECT_DIR}}" ;;
        "~/"*) value="${HOME:-${PROJECT_DIR}}/${value#~/}" ;;
    esac
    case "${value}" in
        /*) printf '%s' "${value}" ;;
        *) printf '%s/%s' "${PROJECT_DIR}" "${value}" ;;
    esac
}

set_runtime_data_dir() {
    HERMES_DATA_DIR="$(normalize_host_path "$1")"
    HERMES_HOME="${HERMES_DATA_DIR}/.hermes"
    HERMES_ENV="${HERMES_HOME}/.env"
    HERMES_CONFIG="${HERMES_HOME}/config.yaml"
    mkdir -p "${HERMES_HOME}"
}

prompt() {
    local label="$1"
    local default="${2:-}"
    local value
    if [ -n "${default}" ]; then
        printf '%s [%s]: ' "${label}" "${default}" >&2
    else
        printf '%s: ' "${label}" >&2
    fi
    read -r value || value=""
    if [ -z "${value}" ]; then
        value="${default}"
    fi
    printf '%s' "${value}"
}

prompt_secret() {
    local label="$1"
    local value
    printf '%s: ' "${label}" >&2
    read -rs value || value=""
    printf '\n' >&2
    printf '%s' "${value}"
}

dotenv_quote() {
    local value="$1"
    value="${value//$'\r'/}"
    value="${value//$'\n'/}"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//\$/\\\$}"
    printf '"%s"' "${value}"
}

select_bind_address() {
    local choice
    printf '\nBind address\n' >&2
    printf '  1) 127.0.0.1 - localhost only; safest behind SSH tunnel/reverse proxy\n' >&2
    printf '  2) 0.0.0.0 - all interfaces; only use behind firewall/reverse proxy\n' >&2
    printf '  3) custom\n' >&2
    choice="$(prompt "Choose" "1")"
    case "${choice}" in
        1|"127.0.0.1") printf '127.0.0.1' ;;
        2|"0.0.0.0") printf '0.0.0.0' ;;
        3|custom) prompt "Bind published ports to address" "127.0.0.1" ;;
        *) printf '%s' "${choice}" ;;
    esac
}

select_deployment_profile() {
    local choice
    printf '\nDeployment profile\n' >&2
    printf '  1) server - no direct host ports; use a reverse proxy or VPN\n' >&2
    printf '  2) local  - publish desktop, gateway, and dashboard ports to the host\n' >&2
    choice="$(prompt "Choose" "1")"
    case "${choice}" in
        1|server|remote) printf 'server' ;;
        2|local) printf 'local' ;;
        *) printf '%s' "${choice}" ;;
    esac
}

validate_deployment_profile() {
    local value="$1"
    case "${value}" in
        local|server) return 0 ;;
    esac
    say "Invalid deployment profile: ${value}"
    say "Use local or server."
    exit 1
}

validate_bind_address() {
    local value="$1"
    if [[ "${value}" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || [ "${value}" = "localhost" ]; then
        return 0
    fi
    say "Invalid bind address: ${value}"
    say "Use an IP like 127.0.0.1 or 0.0.0.0."
    exit 1
}

validate_port() {
    local label="$1"
    local value="$2"
    if [[ "${value}" =~ ^[0-9]+$ ]] && [ "${value}" -ge 1 ] && [ "${value}" -le 65535 ]; then
        return 0
    fi
    say "Invalid ${label}: ${value}"
    say "Use a TCP port from 1 to 65535."
    exit 1
}

write_compose_env() {
    local instance_name="$1"
    local container_name="$2"
    local deployment_profile="$3"
    local runtime_data_dir="$4"
    local desktop_user="$5"
    local desktop_password="$6"
    local bind_address="$7"
    local desktop_https_port="$8"
    local desktop_http_port="$9"
    local gateway_port="${10}"
    local dashboard_port="${11}"
    local dashboard_user="${12}"
    local dashboard_password="${13}"

    {
        printf '# Generated by ./setup-hermes-env. Used by docker compose.\n'
        printf 'COMPOSE_PROJECT_NAME=%s\n' "$(dotenv_quote "${instance_name}")"
        printf 'HERMES_CONTAINER_NAME=%s\n' "$(dotenv_quote "${container_name}")"
        printf 'COMPOSE_PROFILES=%s\n' "$(dotenv_quote "${deployment_profile}")"
        printf 'HERMES_CONFIG_VOLUME=%s\n' "$(dotenv_quote "${runtime_data_dir}")"
        printf 'HERMES_BACKUP_DIR=%s\n' "$(dotenv_quote "${runtime_data_dir%/}-backups")"
        printf 'CUSTOM_USER=%s\n' "$(dotenv_quote "${desktop_user}")"
        printf 'PASSWORD=%s\n' "$(dotenv_quote "${desktop_password}")"
        printf 'TITLE=%s\n' "$(dotenv_quote "Hermes Desktop")"
        printf 'PUID=1000\n'
        printf 'PGID=1000\n'
        printf 'TZ=%s\n' "$(dotenv_quote "Etc/UTC")"
        printf 'PIXELFLUX_WAYLAND=false\n'
        printf 'HERMES_BIND_ADDRESS=%s\n' "$(dotenv_quote "${bind_address}")"
        printf 'HERMES_DESKTOP_HTTPS_HOST_PORT=%s\n' "$(dotenv_quote "${desktop_https_port}")"
        printf 'HERMES_DESKTOP_HTTP_HOST_PORT=%s\n' "$(dotenv_quote "${desktop_http_port}")"
        printf 'HERMES_GATEWAY_HOST_PORT=%s\n' "$(dotenv_quote "${gateway_port}")"
        printf 'HERMES_DASHBOARD_HOST_PORT=%s\n' "$(dotenv_quote "${dashboard_port}")"
        printf 'HERMES_DASHBOARD=1\n'
        printf 'HERMES_DASHBOARD_HOST=0.0.0.0\n'
        printf 'HERMES_DASHBOARD_PORT=9119\n'
        printf 'HERMES_DASHBOARD_BASIC_AUTH_USERNAME=%s\n' "$(dotenv_quote "${dashboard_user}")"
        printf 'HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=%s\n' "$(dotenv_quote "${dashboard_password}")"
        printf 'FASTER_WHISPER_HOME=%s\n' "$(dotenv_quote "/config/.cache/faster-whisper")"
        printf 'HF_HOME=%s\n' "$(dotenv_quote "/config/.cache/huggingface")"
        printf 'OBSIDIAN_AUTOSTART=0\n'
    } > "${COMPOSE_ENV}"
    chmod 600 "${COMPOSE_ENV}" 2>/dev/null || true
}

upsert_hermes_env() {
    local key="$1"
    local value="$2"
    local tmp

    touch "${HERMES_ENV}"
    tmp="$(mktemp)"
    grep -v -E "^${key}=" "${HERMES_ENV}" > "${tmp}" || true
    printf '%s=%s\n' "${key}" "$(dotenv_quote "${value}")" >> "${tmp}"
    mv "${tmp}" "${HERMES_ENV}"
    chmod 600 "${HERMES_ENV}" 2>/dev/null || true
}

seed_hermes_runtime_env() {
    [ -f "${HERMES_ENV}" ] || touch "${HERMES_ENV}"
    upsert_hermes_env API_SERVER_ENABLED true
    upsert_hermes_env API_SERVER_HOST 0.0.0.0
    upsert_hermes_env API_SERVER_PORT 8642
    upsert_hermes_env API_SERVER_MODEL_NAME hermes-agent
    if ! grep -q '^API_SERVER_KEY=' "${HERMES_ENV}" 2>/dev/null; then
        upsert_hermes_env API_SERVER_KEY "$(generate_secret)"
    fi
    upsert_hermes_env GATEWAY_ALLOW_ALL_USERS false
    upsert_hermes_env BROWSER_CDP_URL ws://127.0.0.1:9222
    upsert_hermes_env BU_CDP_URL http://127.0.0.1:9222
    upsert_hermes_env BROWSER_HARNESS_HOME /config/.browser-harness
    upsert_hermes_env BH_HOME /config/.browser-harness
    upsert_hermes_env BH_DOMAIN_SKILLS 0
    upsert_hermes_env BROWSER_INACTIVITY_TIMEOUT 3600
    if ! grep -q '^HERMES_DASHBOARD_BASIC_AUTH_SECRET=' "${HERMES_ENV}" 2>/dev/null; then
        upsert_hermes_env HERMES_DASHBOARD_BASIC_AUTH_SECRET "$(generate_secret)"
    fi
}

seed_hermes_config() {
    if [ ! -f "${HERMES_CONFIG}" ] && [ -f "${DEFAULT_CONFIG}" ]; then
        cp "${DEFAULT_CONFIG}" "${HERMES_CONFIG}"
    fi
}

write_server_config() {
    local instance_name container_name
    local runtime_data_dir desktop_user desktop_password bind_address dashboard_user dashboard_password
    local desktop_https_port desktop_http_port gateway_port dashboard_port

    say
    DEPLOYMENT_PROFILE="$(select_deployment_profile)"
    validate_deployment_profile "${DEPLOYMENT_PROFILE}"

    say
    say "Instance"
    DEFAULT_INSTANCE_NAME="$(sanitize_instance_name "$(basename "${PROJECT_DIR}")")"
    instance_name="$(prompt "Instance name" "${DEFAULT_INSTANCE_NAME}")"
    instance_name="$(sanitize_instance_name "${instance_name}")"
    container_name="$(prompt "Container name" "${instance_name}")"
    container_name="$(sanitize_instance_name "${container_name}")"
    if [ "${DEPLOYMENT_PROFILE}" = "server" ]; then
        runtime_data_dir="$(prompt "Runtime state path" "${HOME:-${PROJECT_DIR}}/.local/share/${instance_name}")"
    else
        runtime_data_dir="$(prompt "Runtime state path" "${PROJECT_DIR}/data")"
    fi
    set_runtime_data_dir "${runtime_data_dir}"

    say
    say "Server access"
    desktop_user="$(prompt "Selkies desktop username" "abc")"
    desktop_password="$(prompt_secret "Selkies desktop password (blank = generate)")"
    if [ -z "${desktop_password}" ]; then
        desktop_password="$(generate_secret)"
        GENERATED_DESKTOP_PASSWORD="${desktop_password}"
    fi
    if [ "${DEPLOYMENT_PROFILE}" = "local" ]; then
        bind_address="$(select_bind_address)"
        validate_bind_address "${bind_address}"
        say
        say "Published host ports"
        desktop_https_port="$(prompt "Selkies HTTPS host port" "3001")"
        validate_port "Selkies HTTPS host port" "${desktop_https_port}"
        desktop_http_port="$(prompt "Selkies HTTP host port" "3000")"
        validate_port "Selkies HTTP host port" "${desktop_http_port}"
        gateway_port="$(prompt "Gateway host port" "8642")"
        validate_port "Gateway host port" "${gateway_port}"
        dashboard_port="$(prompt "Dashboard host port" "9119")"
        validate_port "Dashboard host port" "${dashboard_port}"
    else
        bind_address="127.0.0.1"
        desktop_https_port="3001"
        desktop_http_port="3000"
        gateway_port="8642"
        dashboard_port="9119"
    fi
    dashboard_user="$(prompt "Dashboard username" "${desktop_user}")"
    dashboard_password="$(prompt_secret "Dashboard password (blank = use desktop password)")"
    if [ -z "${dashboard_password}" ]; then
        dashboard_password="${desktop_password}"
        DASHBOARD_REUSES_DESKTOP_PASSWORD=true
    fi

    write_compose_env \
        "${instance_name}" \
        "${container_name}" \
        "${DEPLOYMENT_PROFILE}" \
        "${HERMES_DATA_DIR}" \
        "${desktop_user}" \
        "${desktop_password}" \
        "${bind_address}" \
        "${desktop_https_port}" \
        "${desktop_http_port}" \
        "${gateway_port}" \
        "${dashboard_port}" \
        "${dashboard_user}" \
        "${dashboard_password}"
}

ensure_image() {
    if docker image inspect hermes-docker >/dev/null 2>&1; then
        return 0
    fi

    say
    say "Docker image 'hermes-docker' was not found."
    say "Building it now. This can take a while on the first run."
    docker build -t hermes-docker "${PROJECT_DIR}"
}

print_generated_credentials() {
    if [ -z "${GENERATED_DESKTOP_PASSWORD}" ]; then
        return 0
    fi

    say
    say "Generated credentials"
    say "  Selkies desktop password: ${GENERATED_DESKTOP_PASSWORD}"
    if [ "${DASHBOARD_REUSES_DESKTOP_PASSWORD}" = true ]; then
        say "  Dashboard password: same as Selkies desktop password"
    fi
    say "These were also written to ${COMPOSE_ENV}."
}

run_hermes_setup() {
    say
    say "Starting Hermes' native setup wizard inside Docker."
    say "Hermes will write provider/model/auth files into ${HERMES_HOME}."
    say

    docker run --rm -it \
        -v "${HERMES_DATA_DIR}:/config" \
        -e HOME=/config \
        -e HERMES_HOME=/config/.hermes \
        --entrypoint hermes \
        hermes-docker setup "$@"
}

main() {
    say "Hermes Docker setup"
    say "This script writes Docker server config, seeds minimal Hermes runtime env,"
    say "then runs the official Hermes setup wizard inside the hermes-docker image."
    say
    say "Files:"
    say "  ${COMPOSE_ENV}"
    say "  runtime state path selected during setup"

    if ! command -v docker >/dev/null 2>&1; then
        say "docker is required."
        exit 1
    fi

    write_server_config
    seed_hermes_runtime_env
    seed_hermes_config
    ensure_image
    print_generated_credentials
    run_hermes_setup "$@"

    say
    say "Done. Start Hermes with:"
    say "  docker compose up -d"
    say
    say "Runtime state path:"
    say "  ${HERMES_DATA_DIR}"
}

main "$@"
