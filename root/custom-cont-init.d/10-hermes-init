#!/usr/bin/with-contenv bash
# Seed Hermes state into the persistent /config volume on first start.
#
# Anything outside /config is baked into the image; /config is replaced by the
# mounted volume at runtime. The Hermes installer placed Node.js and the managed
# uv binary in the build-time data dir (/opt/hermes/.hermes); we symlink those
# into HERMES_HOME so browser tools resolve against the fresh volume. Symlinks
# (not copies) keep them in sync with image upgrades and avoid bloating /config.

HERMES_HOME=/config/.hermes
BAKED=/opt/hermes/.hermes

mkdir -p "${HERMES_HOME}" /config/.brave

# Seed the default Hermes config only if the user has none yet.
if [ ! -f "${HERMES_HOME}/config.yaml" ] && [ -f /defaults/hermes/config.yaml ]; then
    cp /defaults/hermes/config.yaml "${HERMES_HOME}/config.yaml"
    echo "[hermes-init] Seeded default config at ${HERMES_HOME}/config.yaml"
fi

# Link installer-managed runtime deps (Node for browser tools, managed uv).
for item in node bin; do
    if [ -e "${BAKED}/${item}" ]; then
        ln -sfn "${BAKED}/${item}" "${HERMES_HOME}/${item}"
    fi
done

# Own the real (non-symlink) state with the hermes user; leave symlinks pointing at
# the root-owned, world-readable baked trees.
find "${HERMES_HOME}" -maxdepth 1 -mindepth 1 ! -type l -exec chown -R hermes:hermes {} + 2>/dev/null || true
chown -h hermes:hermes "${HERMES_HOME}"/node "${HERMES_HOME}"/bin 2>/dev/null || true
chown hermes:hermes "${HERMES_HOME}" /config/.brave 2>/dev/null || true

# Stale Brave profile locks block a new window after a crash.
rm -f /config/.brave/SingletonLock /config/.brave/SingletonSocket /config/.brave/SingletonCookie 2>/dev/null || true

# Brave + Hermes terminal launch via /defaults/launch-desktop*.sh (see autostart).
# Bump version when launch scripts or autostart change.
DESKTOP_AUTOSTART_VERSION=4
sync_desktop_autostart() {
    local conf_dir="$1"
    local def_autostart="$2"
    local def_menu="$3"
    local marker="${conf_dir}/.hermes-autostart-version"
    local target="${conf_dir}/autostart"

    mkdir -p "${conf_dir}"
    if [ ! -f "${marker}" ] || [ "$(cat "${marker}" 2>/dev/null)" != "${DESKTOP_AUTOSTART_VERSION}" ] \
        || [ ! -f "${target}" ] || ! grep -q 'launch-desktop' "${target}" 2>/dev/null \
        || grep -q '\\$' "${target}" 2>/dev/null; then
        cp "${def_autostart}" "${target}"
        echo "${DESKTOP_AUTOSTART_VERSION}" > "${marker}"
        chown hermes:hermes "${marker}" "${target}" 2>/dev/null || true
        echo "[hermes-init] Refreshed desktop autostart at ${target}"
    fi
    if [ -n "${def_menu}" ] && [ -f "${def_menu}" ]; then
        if [ ! -f "${conf_dir}/menu.xml" ] || ! grep -q 'brave-browser' "${conf_dir}/menu.xml" 2>/dev/null; then
            cp "${def_menu}" "${conf_dir}/menu.xml"
            echo "[hermes-init] Refreshed desktop menu at ${conf_dir}/menu.xml"
        fi
    fi
    chown -R hermes:hermes "${conf_dir}" 2>/dev/null || true
}

sync_desktop_autostart /config/.config/openbox /defaults/autostart /defaults/menu.xml
sync_desktop_autostart /config/.config/labwc /defaults/autostart_wayland /defaults/menu_wayland.xml

# If the user copied an existing Hermes home, ensure browser automation is configured.
if [ -f "${HERMES_HOME}/config.yaml" ] && ! grep -q '^browser:' "${HERMES_HOME}/config.yaml" 2>/dev/null; then
    cat >> "${HERMES_HOME}/config.yaml" <<'EOF'

browser:
  cdp_url: ws://127.0.0.1:9222
EOF
    echo "[hermes-init] Appended browser.cdp_url to ${HERMES_HOME}/config.yaml"
    chown hermes:hermes "${HERMES_HOME}/config.yaml" 2>/dev/null || true
fi
if [ -f "${HERMES_HOME}/config.yaml" ] && ! grep -q 'browser' "${HERMES_HOME}/config.yaml" 2>/dev/null; then
    if grep -q '^toolsets:' "${HERMES_HOME}/config.yaml" 2>/dev/null \
        && ! grep -A20 '^toolsets:' "${HERMES_HOME}/config.yaml" | grep -q 'browser'; then
        sed -i '/^toolsets:/a\  - browser' "${HERMES_HOME}/config.yaml"
        echo "[hermes-init] Added browser toolset to ${HERMES_HOME}/config.yaml"
        chown hermes:hermes "${HERMES_HOME}/config.yaml" 2>/dev/null || true
    fi
fi
