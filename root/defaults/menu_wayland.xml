<?xml version="1.0" encoding="utf-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
  <menu id="root-menu" label="MENU">
    <item label="Brave Browser">
      <action name="Execute">
        <command>brave-browser --remote-debugging-port=9222 --remote-debugging-address=127.0.0.1 --user-data-dir=/config/.brave --ozone-platform-hint=auto --no-sandbox --no-first-run --no-default-browser-check</command>
      </action>
    </item>
    <item label="Hermes (terminal)">
      <action name="Execute">
        <command>foot -T Hermes bash -lc "hermes || true; exec bash"</command>
      </action>
    </item>
    <item label="Obsidian">
      <action name="Execute">
        <command>obsidian</command>
      </action>
    </item>
    <item label="Terminal">
      <action name="Execute">
        <command>foot</command>
      </action>
    </item>
  </menu>
</openbox_menu>
