# Minimal Hermes runtime env seeded into /config/.hermes/.env on first boot.
#
# This file intentionally contains no model-provider API keys. Prefer running
# ./setup-hermes-env on the host before `docker compose up`; this file is only
# a runtime fallback when /config/.hermes/.env does not already exist.

# The gateway API server backs the WebUI on port 8642.
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8642
API_SERVER_MODEL_NAME=hermes-agent
API_SERVER_KEY=__GENERATED_API_SERVER_KEY__

# Keep gateway access closed until the user configures explicit allowlists.
GATEWAY_ALLOW_ALL_USERS=false

# Keep browser tools attached to the visible Brave instance.
BROWSER_CDP_URL=ws://127.0.0.1:9222
BU_CDP_URL=http://127.0.0.1:9222
BROWSER_HARNESS_HOME=/config/.browser-harness
BH_HOME=/config/.browser-harness
BH_DOMAIN_SKILLS=0
BROWSER_INACTIVITY_TIMEOUT=3600

# Local Telegram/Discord/etc. voice transcription. Hermes converts voice notes
# with ffmpeg, then this command writes the transcript into Hermes' temp dir.
HERMES_LOCAL_STT_COMMAND="faster-whisper-transcribe {input_path} --model {model} --language {language} --format text > {output_dir}/transcript.txt"
HERMES_LOCAL_STT_LANGUAGE=en

# Make dashboard basic-auth sessions survive process restarts.
HERMES_DASHBOARD_BASIC_AUTH_SECRET=__GENERATED_DASHBOARD_SECRET__
